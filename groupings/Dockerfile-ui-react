#Dockerfile-ui-react - UH Groupings UI - enable hot updates from the editor in local machine

# Use Node image
FROM node:21-alpine

#Username will be provided by docker-compose (matches host machine username)
ARG USERNAME

#Create a non-root user inside the container
RUN addgroup -S ${USERNAME} \
    && adduser -S ${USERNAME} -G ${USERNAME}

#Set working directory
WORKDIR /app/groupings/ui

#Switch to the non-root user
USER ${USERNAME}

#Copy only package files to leverage Docker layer caching
#This ensures npm install only re-runs if dependencies actually change
COPY --chown=${USERNAME}:${USERNAME} package*.json ./

#Install development dependencies during build time
#The node_modules directory is mounted as a named volume to persist dependencies between restarts
RUN npm install

#Source code is mounted as a volume, so no need to copy it here

CMD ["sh", "-c", "npm run ${NODE_PROFILES_ACTIVE}"]
